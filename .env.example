# FirstStep — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Neon PostgreSQL (get from https://neon.tech) ───────────────────────────
# After creating your Neon project, copy the connection string here.
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=

# ─── JWT Secret ─────────────────────────────────────────────────────────────
# Generate a strong random string. Example: openssl rand -hex 32
JWT_SECRET=change-this-to-a-strong-random-secret-before-production

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Gemini AI (Optional — users can set their own key inside the app) ───────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
